<mvc:View
    controllerName="my.app.generatebill.controller.View"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:uxap="sap.uxap"
    displayBlock="true"
>
    <uxap:ObjectPageLayout
        id="ObjectPageLayout"
        upperCaseAnchorBar="false"
        showFooter="true"
    >
        <uxap:headerTitle>
            <uxap:ObjectPageHeader objectTitle="IN-TELECOM SERVICES">
                <Select
                    id="mySelect"
                    change=".onSelectChange"
                >
                    <items>
                        <core:Item
                            key="Quote"
                            text="Quotation"
                        />
                        <core:Item
                            key="TaxInv"
                            text="TAX-INVOICE"
                        />
                        <core:Item
                            key="CashBill"
                            text="Cash Bill"
                        />
                    </items>
                </Select>
            </uxap:ObjectPageHeader>
        </uxap:headerTitle>

        <uxap:sections>
            <uxap:ObjectPageSection
                id="idOPSQuote1"
                titleUppercase="false"
                title="Quotation Details"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Quotation Details"
                        titleUppercase="false"
                    >
                        <f:SimpleForm
                            editable="true"
                            layout="ColumnLayout"
                        >
                            <f:content>
                                <Label text="To (Name and Address)" />
                                <TextArea
                                    value="{/header/To}"
                                    placeholder="e.g., Mr. Patil"
                                    rows="2"
                                />
                                <Label text="Date" />
                                <DatePicker
                                    value="{/header/Date}"
                                    valueFormat="dd-MM-yyyy"
                                    displayFormat="long"
                                    placeholder="dd-MM-yyyy"
                                />

                                <Label text="Subject" />
                                <TextArea
                                    value="{/header/Subject}"
                                    rows="2"
                                    growing="true"
                                    placeholder="e.g., Supply and Installment of camera"
                                />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="idOPSQuote2"
                titleUppercase="false"
                title="Additional Information"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Additional Information"
                        titleUppercase="false"
                    >
                        <f:SimpleForm
                            editable="true"
                            layout="ColumnLayout"
                        >
                            <f:content>
                                <Label text="Notes" />
                                <TextArea
                                    value="{/header/Notes}"
                                    rows="3"
                                    placeholder="Enter specific notes (e.g., 18% GST included in Quotation)"
                                />

                                <Label text="Terms &amp; Conditions" />
                                <TextArea
                                    value="{/header/TermsAndConditions}"
                                    rows="5"
                                    placeholder="Enter specific Terms and Condition (e.g., 100% Advance)"
                                />
                                <Label text="Bank Details" />
                                <TextArea
                                    value="{/header/BankDetails}"
                                    rows="7"
                                />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="idOPSQuoteTaxInc"
                titleUppercase="false"
                title="Tax Invoice Details"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Tax Invoice Details"
                        titleUppercase="false"
                    >
                        <f:SimpleForm
                            editable="true"
                            layout="ColumnLayout"
                        >
                            <f:content>
                                <Label text="To" />
                                <TextArea
                                    value="{/taxHeader/To}"
                                    rows="3"
                                    placeholder="Name and Address"
                                />

                                <Label text="GST No" />
                                <Input
                                    value="{/taxHeader/GSTNo}"
                                    placeholder="Enter GST No"
                                />
                                <Label text="Invoice No" />
                                <Input
                                    value="{/taxHeader/InvoiceNo}"
                                    placeholder="Enter Invoice No"
                                />
                                <Label text="Date" />
                                <DatePicker
                                    value="{/taxHeader/Date}"
                                    valueFormat="dd-MM-yyyy"
                                    displayFormat="long"
                                    placeholder="dd-MM-yyyy"
                                />
                                <Label text="PO No" />
                                <Input
                                    value="{/taxHeader/PONo}"
                                    placeholder="Enter PO No"
                                />
                                <Label text="PO Date" />
                                <Input
                                    value="{/taxHeader/PODate}"
                                    placeholder="Enter PO Date"
                                />
                                <Label text="Bank Details" />
                                <TextArea
                                    value="{/taxHeader/BankDetails}"
                                    rows="7"
                                />
                                <Label text="Party GST No" />
                                <Input
                                    value="{/taxHeader/PartyGST}"
                                    placeholder="Enter Party GST"
                                />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="idQuotationSec"
                titleUppercase="false"
                title="Quotation - Particulars"
                showTitle="false"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Quotation - Particulars"
                        titleUppercase="false"
                        showTitle="false"
                    >
                        <VBox>
                            <Table
                                id="idProductsTable"
                                items="{/products}"
                                mode="Delete"
                                delete=".onDelete"
                                sticky="ColumnHeaders,HeaderToolbar,InfoToolbar"
                            >
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="Line Items" />
                                        <ToolbarSpacer />
                                        <Button
                                            icon="sap-icon://add"
                                            text="Add Row"
                                            press=".onAddRow"
                                        />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column visible="false">
                                        <Text text="No" />
                                    </Column>
                                    <Column>
                                        <Text text="Particulars" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Qty" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Rate" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Total" />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text
                                                text="{= ${/products}.indexOf(${path: ''}) + 1 }"
                                            />
                                            <TextArea value="{productName}" />
                                            <Input
                                                value="{quantity}"
                                                change=".onCalc"
                                            />
                                            <HBox>
                                                <Input
                                                    value="{price}"
                                                    change=".onCalc"
                                                />
                                                <Input value="{symbol}" />
                                            </HBox>
                                            <Text text="{total}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <Title text="GST(18%):" />
                                <Title text="{/gst}" />
                            </OverflowToolbar>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <Title text="Grand Total:" />
                                <Title text="{/totalSum}" />
                            </OverflowToolbar>
                        </VBox>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="idTaxSec"
                titleUppercase="false"
                title="Tax Invoice - Particulars"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Tax Invoice - Particulars"
                        titleUppercase="false"
                        showTitle="false"
                    >
                        <VBox>
                            <Table
                                id="idTaxInvcTable"
                                items="{/taxProducts}"
                                mode="Delete"
                                delete=".onTaxDelete"
                                sticky="ColumnHeaders,HeaderToolbar,InfoToolbar"
                            >
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="Line Items" />
                                        <ToolbarSpacer />
                                        <Button
                                            icon="sap-icon://add"
                                            text="Add Row"
                                            press=".onTaxAddRow"
                                        />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column visible="false">
                                        <Text text="No" />
                                    </Column>
                                    <Column>
                                        <Text text="Particulars" />
                                    </Column>
                                    <Column>
                                        <Text text="HSN Code" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Qty" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Rate and Symbol" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Total" />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text
                                                text="{= ${/taxProducts}.indexOf(${path: ''}) + 1 }"
                                            />
                                            <TextArea
                                                value="{taxpProductName}"
                                            />
                                            <Input value="{taxHSNCode}" />
                                            <Input
                                                value="{taxQuantity}"
                                                change=".onTaxCalc"
                                            />
                                            <HBox>
                                                <Input
                                                    value="{taxPrice}"
                                                    change=".onTaxCalc"
                                                />
                                                <Input
                                                    value="{taxSymbol}"
                                                    placeholder="eg. R.T.M"
                                                />
                                            </HBox>
                                            <Text text="{taxTotal}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <Title text="Total" />
                                <Title text="{/taxtotal}" />
                            </OverflowToolbar>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <Title text="CGST @ 9" />
                                <Title text="{/taxcgst}" />
                            </OverflowToolbar>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <Title text="SGST @ 9" />
                                <Title text="{/taxsgst}" />
                            </OverflowToolbar>
                            <OverflowToolbar>
                                <ToolbarSpacer />
                                <Title text="Grand Total:" />
                                <Title text="{/taxtotalSum}" />
                            </OverflowToolbar>
                        </VBox>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="idOPSCash"
                titleUppercase="false"
                title="Cash Bill Details"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Cash Bill Details"
                        titleUppercase="false"
                    >
                        <f:SimpleForm
                            editable="true"
                            layout="ColumnLayout"
                        >
                            <f:content>
                                <Label text="To" />
                                <TextArea
                                    value="{/cashHeader/cashTo}"
                                    rows="3"
                                    placeholder="Name and Address"
                                />

                                <Label text="Date" />
                                <DatePicker
                                    value="{/cashHeader/cashDate}"
                                    valueFormat="dd-MM-yyyy"
                                    displayFormat="long"
                                    placeholder="dd-MM-yyyy"
                                />

                                <Label text="Bank Details" />
                                <TextArea
                                    value="{/cashHeader/cashbankDetails}"
                                    rows="7"
                                />
                            </f:content>
                        </f:SimpleForm>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="idCashSecTab"
                titleUppercase="false"
                title="Tax Invoice - Particulars"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        title="Cash Bill - Particulars"
                        titleUppercase="false"
                        showTitle="false"
                    >
                        <VBox>
                            <Table
                                id="idCashTable"
                                items="{/cashProducts}"
                                mode="Delete"
                                delete=".onCashDelete"
                                sticky="ColumnHeaders,HeaderToolbar,InfoToolbar"
                            >
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="Line Items" />
                                        <ToolbarSpacer />
                                        <Button
                                            icon="sap-icon://add"
                                            text="Add Row"
                                            press=".onCashAddRow"
                                        />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column visible="false">
                                        <Text text="No" />
                                    </Column>
                                    <Column width="60%">
                                        <Text text="Particulars" />
                                    </Column>
                                    <Column hAlign="Center">
                                        <Text text="Quantity" />
                                    </Column>

                                    <Column hAlign="Center">
                                        <Text text="Amount" />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text
                                                text="{= ${/cashProducts}.indexOf(${path: ''}) + 1 }"
                                            />
                                            <TextArea value="{cashBody}" width="40rem"/>
                                            <Input value="{cashQuantity}" />
                                            <Input value="{cashAmount}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
        <uxap:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    id="idBtnQuotation"
                    icon="sap-icon://pdf-attachment"
                    text="Generate Quotation"
                    type="Transparent"
                    press="onGeneratePDF"
                />
                <Button
                    id="idBtnInvoice"
                    icon="sap-icon://pdf-attachment"
                    text="Tax Invoice"
                    type="Transparent"
                    press="onTaxInvoicePDF"
                />

                  <Button
                    id="idBtnCash"
                    icon="sap-icon://pdf-attachment"
                    text="Bill Cash"
                    type="Transparent"
                    press="onCashBillPDF"
                />
                <CheckBox
                    id="chkTotal"
                    text="Total + GST"
                    select="onTotalSelect"
                />
                <CheckBox
                    id="chkGST"
                    text="GST Amount"
                    select="onGSTSelect"
                />
                <CheckBox
                    id="chkBankDetail"
                    text="Bank Details"
                    select="onGSTSelect"
                />
            </OverflowToolbar>
        </uxap:footer>
    </uxap:ObjectPageLayout>
</mvc:View>
