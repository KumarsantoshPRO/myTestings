<mvc:View
    controllerName="my.app.generatebill.controller.View"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true"
>
    <Page
        title="Quotation"
        titleAlignment="Center"
    >
        <content>
            <Panel
                headerText="Quotation Details"
                expandable="true"
                expanded="true"
                width="auto"
                class="sapUiSmallMargin"
            >
                <f:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                >
                    <f:content>
                        <Label text="Date" />
                        <DatePicker
                            value="{/header/Date}"
                            valueFormat="dd-MM-yyyy"
                            displayFormat="long"
                            placeholder="dd-MM-yyyy"
                            
                        />

                        <Label text="To (Customer Name)" />
                        <TextArea
                            value="{/header/To}"
                            placeholder="e.g., Mr. Patil"
                        />

                        <Label text="Location" />
                        <Input
                            value="{/header/Location}"
                            placeholder="e.g., Bangalore"
                        />

                        <Label text="Subject" />
                        <TextArea
                            value="{/header/Subject}"
                            rows="2"
                            growing="true"
                            placeholder="e.g., Supply and Installment of camera"
                        />
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <Panel
                headerText="Additional Information"
                expandable="true"
                expanded="false"
                width="auto"
                class="sapUiSmallMargin"
            >
                <f:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                >
                    <f:content>
                        <Label text="Notes" />
                        <TextArea
                            value="{/header/Notes}"
                            rows="3"
                            placeholder="Enter specific notes (e.g., 18% GST included in Quotation)"
                        />

                        <Label text="Terms &amp; Conditions" />
                        <TextArea
                            value="{/header/TermsAndConditions}"
                            rows="5"
                            placeholder="Enter specific Terms and Condition (e.g., 100% Advance)"
                        />
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <Table
                id="idProductsTable"
                items="{/products}"
                mode="Delete"
                delete=".onDelete"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Line Items" />
                        <ToolbarSpacer />
                        <Button
                            icon="sap-icon://add"
                            text="Add Row"
                            press=".onAddRow"
                        />
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="12%">
                        <Text text="Sl.No" />
                    </Column>
                    <Column width="40%">
                        <Text text="Particulars" />
                    </Column>
                    <Column
                        hAlign="Center"
                        width="15%"
                    >
                        <Text text="Qty" />
                    </Column>
                    <Column
                        hAlign="Center"
                        width="15%"
                    >
                        <Text text="Rate" />
                    </Column>
                    <Column
                        hAlign="Center"
                        width="15%"
                    >
                        <Text text="Total" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text
                                text="{= ${/products}.indexOf(${path: ''}) + 1 }"
                            />
                            <Input value="{productName}" />
                            <Input
                                value="{quantity}"
                                change=".onCalc"
                            />
                            <Input
                                value="{price}"
                                change=".onCalc"
                            />
                            <Text text="{total}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Title text="GST(18%):" />
                <Title text="{/gst}" />
            </OverflowToolbar>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Title text="Grand Total:" />
                <Title text="{/totalSum}" />
            </OverflowToolbar>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Generate bill"
                    type="Emphasized"
                    press="onGeneratePDF"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
