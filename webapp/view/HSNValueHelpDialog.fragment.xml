<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <TableSelectDialog
        id="hsnValueHelpDialog"
        title="Select HSN Code"
        noDataText="No HSN Codes found"
        search=".onHSNValueHelpSearch"
        confirm=".onHSNValueHelpConfirm"
        items="{hsnModel>/HSN_MSTR}">
        
        <columns>
            <Column width="30%">
                <header>
                    <Text text="HSN Code" />
                </header>
            </Column>
            <Column width="70%">
                <header>
                    <Text text="Description" />
                </header>
            </Column>
        </columns>
        
        <ColumnListItem>
            <cells>
                <Text text="{hsnModel>HSN_CD}" />
                <Text text="{hsnModel>HSN_Description}" />
            </cells>
        </ColumnListItem>
    </TableSelectDialog>
</core:FragmentDefinition>